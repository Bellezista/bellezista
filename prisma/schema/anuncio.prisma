enum TipoAnuncio {
  MAQUINARIA
  // Fase 2 additions (not built in Etapa 1): TRASPASO, TALENT, OFERTA.
  // Adding a case here + a new 1:1 subtype table + a new subtype-adapter is
  // the whole extension path -- see src/lib/anuncio/subtype-adapters.ts.

  @@schema("public")
}

enum EstadoAnuncio {
  ACTIVO
  DESTACADO
  RESERVADO
  VENDIDO
  RETIRADO

  @@schema("public")
}

// Shared parent type for all listing modules (class-table inheritance: Prisma
// has no native polymorphism, so each subtype is a separate 1:1 table keyed by
// the same id, discriminated by `tipo`). This is what lets the catalog/search
// run over a single query as more modules are added later, without duplicating
// screens or workflows -- the idea the client's brief and the winning bid were
// built around.
model Anuncio {
  id              String        @id @default(uuid()) @db.Uuid
  tipo            TipoAnuncio
  titulo          String
  precio          Decimal       @db.Decimal(12, 2)
  ciudadProvincia String        @map("ciudad_provincia")
  fotos           String[]
  estado          EstadoAnuncio @default(ACTIVO)

  propietarioId String  @map("propietario_id") @db.Uuid
  propietario   Usuario @relation(fields: [propietarioId], references: [id])

  // Additive beyond the client's literal field list -- required by the
  // already-confirmed "user panel shows view counts" feature.
  vistas Int @default(0)

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  maquinaria Maquinaria?
  // Fase 2: traspaso Traspaso? -- added here with zero impact on existing rows/columns.

  conversaciones Conversacion[]
  operaciones    Operacion[]

  @@index([tipo, estado])
  @@index([ciudadProvincia])
  @@map("anuncio")
  @@schema("public")
}
