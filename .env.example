# Supabase project settings (Dashboard -> Connect, and Settings -> API Keys)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."

# Prisma runtime connection (app code, via the driver adapter) -- Supavisor
# TRANSACTION-mode pooler, port 6543. `pgbouncer=true` is required (Supavisor
# transaction mode doesn't support prepared statements).
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI connection (prisma.config.ts, migrate/db push/introspect) -- Supavisor
# SESSION-mode pooler, port 5432. Session mode supports the advisory locks
# migrations need and is IPv4-safe (Supabase's raw Direct Connection is
# IPv6-only by default).
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
